{
  "name": "mcp-project",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "dev": "node scripts/dev.js",
    "dev:frontend": "cd frontend && npm --silent run dev",
    "dev:backend": "cd backend && poetry run dev",
    "dev:mcp": "cd generation_mcp_server && poetry run python src/server.py",
    "dev:review": "cd review_mcp_server && poetry run python src/server.py",
    "dev:council": "cd council_mcp_server && poetry run python server_http.py"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "playwright": "^1.58.0"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}
